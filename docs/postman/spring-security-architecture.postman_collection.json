{
  "info": {
    "name": "spring-security-architecture",
    "_postman_id": "3f1d2a3c-7d0d-4d6f-8b1e-0d7a9f2b6c11",
    "description": "Collection de testes manuais para estudo de Spring Security + JWT + FilterChain.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwtToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Login success",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response contains JWT token', function () {",
              "    pm.expect(json.token).to.exist;",
              "    pm.expect(json.token).to.be.a('string');",
              "    pm.expect(json.token.length).to.be.greaterThan(20);",
              "});",
              "",
              "pm.test('Response contains username', function () {",
              "    pm.expect(json.username).to.eql('admin');",
              "});",
              "",
              "pm.test('Response contains roles', function () {",
              "    pm.expect(json.roles).to.be.an('array');",
              "});",
              "",
              "pm.collectionVariables.set('jwtToken', json.token);",
              "console.log('JWT salvo na variável jwtToken');"
            ]
          }
        }
      ]
    },
