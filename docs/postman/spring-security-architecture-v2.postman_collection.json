      "key": "jwtToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Authentication",
      "description": "Requests relacionados ao login e obtenção do JWT.",
      "item": [
        {
          "name": "Login - success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response contains JWT token', function () {",
                  "    pm.expect(json.token).to.exist;",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.expect(json.token.length).to.be.greaterThan(20);",
                  "});",
                  "",
                  "pm.test('Response contains username', function () {",
                  "    pm.expect(json.username).to.eql('admin');",
                  "});",
                  "",
                  "pm.test('Response contains roles', function () {",
                  "    pm.expect(json.roles).to.be.an('array');",
                  "});",
                  "",
                  "pm.collectionVariables.set('jwtToken', json.token);",
                  "console.log('JWT salvo na variável jwtToken');"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - invalid password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"senha-errada\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
